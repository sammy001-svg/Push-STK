; PHP-FPM user settings — cPanel shared hosting
; .user.ini is the correct way to configure PHP when the host uses PHP-FPM.
; .htaccess php_value/php_flag directives are silently ignored by PHP-FPM.
; Changes here take effect within ~5 minutes (PHP-FPM re-reads on the cache TTL).

max_execution_time = 300
max_input_time = 300
memory_limit = 256M
upload_max_filesize = 10M
post_max_size = 12M

; Session hardening
session.cookie_httponly = 1
session.cookie_secure = 1
session.use_strict_mode = 1
session.gc_maxlifetime = 7200

; Suppress errors from browser — log them instead
display_errors = Off
log_errors = On
